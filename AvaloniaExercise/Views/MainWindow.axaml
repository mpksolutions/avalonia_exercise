<Window
    x:Class="AvaloniaExercise.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:AvaloniaExercise.Views"
    xmlns:vm="using:AvaloniaExercise.ViewModels"
    Title="Animals Crossing"
    Width="920"
    Height="580"
    MinWidth="760"
    MinHeight="480"
    x:DataType="vm:MainWindowViewModel"
    Background="{StaticResource WindowBackgroundBrush}"
    Icon="/Assets/icon.ico"
    RequestedThemeVariant="Dark"
    mc:Ignorable="d">

    <Grid ColumnDefinitions="200,*">

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBackgroundBrush}"
            BorderBrush="{StaticResource SidebarBorderBrush}"
            BorderThickness="0,0,1,0">

            <StackPanel Margin="0,28,0,24">

                <StackPanel
                    HorizontalAlignment="Center"
                    Margin="0,0,0,36"
                    Spacing="0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="17"
                        FontWeight="Black"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        LetterSpacing="5"
                        Text="ANIMALS" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="17"
                        FontWeight="Black"
                        Foreground="{StaticResource GreenAccentBrush}"
                        LetterSpacing="5"
                        Text="CROSSING" />
                </StackPanel>

                <views:TrafficLight />

                <views:CrossingRequestButton Margin="0,28,0,0" />

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="52,*">
            <views:PedestrianStatsBar Grid.Row="0" />
            <views:PedestriansSection Grid.Row="1" />
        </Grid>

    </Grid>

</Window>
